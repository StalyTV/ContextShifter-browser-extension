{
  "manifest_version": 3,
  "name": "TaskSnap",
  "description": "TaskSnap browser companion: streams open tabs and window state to the desktop app.",
  "version": "4.2.0",
  "icons": {
    "48": "images/logo_48.png",
    "128": "images/logo_128.png"
  },
  "permissions": [
    "tabs",
    "tabGroups",
    "webNavigation",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.ts"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tasksnap@hasel.ifi.uzh.ch"
    }
  }
}
